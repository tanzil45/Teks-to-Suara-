                          <Activity className="w-2.5 h-2.5 text-indigo-400" />
                          <span>{item.engine === "ai" ? "Suara Neural" : "Local TTS"}</span>
                        </span>
                        <span>{item.timestamp}</span>
                      </div>
                    </div>
                  );
                })
              ) : (
                <div className="flex-1 flex flex-col items-center justify-center p-8 text-center rounded-xl border border-dashed border-[#27272a] min-h-[140px]">
                  <Volume2 className="w-6 h-6 text-zinc-700 mb-2 animate-pulse" />
                  <p className="text-[11px] text-zinc-500 italic max-w-[200px]">
                    Riwayat pembacaan audio kosong. Mulai konversi teks baru untuk menyimpannya di sini.
                  </p>
                </div>
              )}
            </div>
          </div>

          {/* Quick Informative User Guide */}
          <div className="mt-auto bg-gradient-to-r from-violet-950/20 to-indigo-950/20 border border-violet-900/40 rounded-xl p-4 flex gap-3">
            <Info className="w-4 h-4 text-violet-400 shrink-0 mt-0.5" />
            <div className="text-[10px] leading-relaxed text-zinc-400">
              <span className="text-white font-bold block mb-0.5">Informasi Kuota & Format</span>
              Sintesis Neural menggunakan teknologi kecerdasan buatan (TTS) secara server-side. Seluruh riwayat berbasis cache lokal untuk pemutaran ulang secepat kilat tanpa konsumsi kuota tambahan.
            </div>
          </div>

        </aside>
      </div>
    </div>
  );
