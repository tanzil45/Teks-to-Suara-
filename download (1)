const GEMINI_VOICES: VoiceOption[] = [
  { id: "Kore", name: "Kaira (Kore)", lang: "id-ID / en-US", gender: "Perempuan", engine: "ai", baseVoice: "Kore", description: "Sopan, hangat & lembut. Pilihan terpopuler untuk asisten virtual." },
  { id: "Zephyr", name: "Zhafira (Zephyr)", lang: "id-ID / en-US", gender: "Perempuan", engine: "ai", baseVoice: "Zephyr", description: "Rileks, kasual & puitis. Cocok untuk buku audio dan podcast." },
  { id: "Adit-Charon", name: "Adit (Charon)", lang: "id-ID / en-US", gender: "Laki-laki", engine: "ai", baseVoice: "Charon", description: "Pria Formal & Berwibawa. Sangat cocok untuk pidato dan berita resmi." },
  { id: "Baskara-Fenrir", name: "Baskara (Fenrir)", lang: "id-ID / en-US", gender: "Laki-laki", engine: "ai", baseVoice: "Fenrir", description: "Pria Berat & Hangat. Nada tebal khas dokumenter dan ulasan ulasan mendalam." },
  { id: "Dimas-Puck", name: "Dimas (Puck)", lang: "id-ID / en-US", gender: "Laki-laki", engine: "ai", baseVoice: "Puck", description: "Pria Ceria & Ekspresif. Sangat energetik, cocok untuk iklan produk." },
  { id: "Budi-Charon", name: "Budi (Charon)", lang: "id-ID / en-US", gender: "Laki-laki", engine: "ai", baseVoice: "Charon", description: "Pria Dewasa & Santun. Suara edukatif berwibawa, cocok untuk e-learning bisnis." },
  { id: "Wira-Fenrir", name: "Wira (Fenrir)", lang: "id-ID / en-US", gender: "Laki-laki", engine: "ai", baseVoice: "Fenrir", description: "Pria Gagah & Bersahaja. Karismatik untuk mendongeng sejarah atau drama audio." },
  { id: "Raka-Puck", name: "Raka (Puck)", lang: "id-ID / en-US", gender: "Laki-laki", engine: "ai", baseVoice: "Puck", description: "Pria Ramah & Gaul. Gaya asyik santai untuk podcast remaja atau sapaan harian." }
];

// Safe helper helper wrappers to bypass security exceptions when sandboxed inside restricted iframes
const getSpeechSynthesis = (): SpeechSynthesis | null => {
  if (typeof window === "undefined") return null;
  try {
    return window.speechSynthesis || null;
  } catch (e) {
    console.warn("speechSynthesis is blocked or inaccessible in this screen context:", e);
    return null;
  }
};

const safeLocalStorage = {
  getItem: (key: string): string | null => {
    try {
      if (typeof window !== "undefined" && window.localStorage) {
        return window.localStorage.getItem(key);
      }
    } catch (e) {
      console.warn("localStorage read is blocked in this screen context:", e);
    }
    return null;
  },
  setItem: (key: string, value: string): void => {
    try {
      if (typeof window !== "undefined" && window.localStorage) {
        window.localStorage.setItem(key, value);
      }
    } catch (e) {
      console.warn("localStorage write is blocked in this screen context:", e);
    }
  }
};

export default function App() {
  // Principal Speech states
  const [text, setText] = useState<string>(
    "Selamat datang di aplikasi Teks ke Suara. Teknologi kecerdasan buatan Neural AI kami mampu mengubah teks tertulis menjadi suara manusia yang terdengar sangat alami dengan intonasi bernyawa. Silakan masukkan naskah Anda, pilih karakter suara di panel kanan, dan nikmati hasil suaranya secara instan."
  );
  const [selectedEngine, setSelectedEngine] = useState<"ai" | "system">("ai");
  const [selectedVoiceId, setSelectedVoiceId] = useState<string>("Kore");
  const [aiEmotion, setAiEmotion] = useState<string>("normal");
  const [speed, setSpeed] = useState<number>(1.0);
  const [pitch, setPitch] = useState<number>(1.0);
  
  // Audio playback status
  const [isGenerating, setIsGenerating] = useState<boolean>(false);
  const [isPlaying, setIsPlaying] = useState<boolean>(false);
  const [activeAudioUrl, setActiveAudioUrl] = useState<string | null>(null);
  const [activeAudioBlob, setActiveAudioBlob] = useState<Blob | null>(null);
  const [activeHistoryPlayingId, setActiveHistoryPlayingId] = useState<string | null>(null);
  const [activeHistoryDownloadId, setActiveHistoryDownloadId] = useState<string | null>(null);
  const [copiedId, setCopiedId] = useState<string | null>(null);
  
  // System local speech synthesis voices loaded dynamically
  const [systemVoices, setSystemVoices] = useState<VoiceOption[]>([]);
  const [activePresetCategory, setActivePresetCategory] = useState<string>("Gaya Pidato/Formal");
  const [history, setHistory] = useState<HistoryItem[]>([]);
  const [toastMessage, setToastMessage] = useState<{ type: "success" | "error" | "info"; text: string } | null>(null);

  // Custom user Gemini API Key state & toggles
  const [geminiApiKey, setGeminiApiKey] = useState<string>(() => {
    return safeLocalStorage.getItem("gemini_api_key") || "";
  });
  const [inputApiKey, setInputApiKey] = useState<string>(() => {
    return safeLocalStorage.getItem("gemini_api_key") || "";
  });
  const [showApiKey, setShowApiKey] = useState<boolean>(false);
  const [isValidatingKey, setIsValidatingKey] = useState<boolean>(false);

  // HTML Audio instance for playing the AI synthesized voice
  const audioRef = useRef<HTMLAudioElement | null>(null);
  // Keep track of systemic voice speech synthesis object
  const utteranceRef = useRef<SpeechSynthesisUtterance | null>(null);

  // Initialize & load local speech voices and search history
  useEffect(() => {
    // Determine history from localStorage
    const saved = safeLocalStorage.getItem("tts_history_logs");
    if (saved) {
      try {
        setHistory(JSON.parse(saved));
      } catch (e) {
        console.error("Gagal memuat riwayat", e);
      }
    }

    // Load standard browser Speech Synthesis voices
    const loadSystemVoices = () => {
      const synth = getSpeechSynthesis();
      if (synth) {
        try {
          const voices = synth.getVoices();
          if (voices && voices.length > 0) {
            const mapped: VoiceOption[] = voices
              .filter(v => v && v.lang && (v.lang.startsWith("id") || v.lang.startsWith("en") || v.lang.startsWith("ms")))
              .map(v => {
                const voiceName = v.name || "Default Voice";
                const nameLower = voiceName.toLowerCase();
                let gender: "Laki-laki" | "Perempuan" | "Netral" = "Netral";
                if (nameLower.includes("female") || nameLower.includes("zira") || nameLower.includes("susan") || nameLower.includes("hazel") || nameLower.includes("google wanita") || nameLower.includes("mei-jia") || nameLower.includes("kore") || nameLower.includes("damayanti")) {
                  gender = "Perempuan";
                } else if (nameLower.includes("male") || nameLower.includes("david") || nameLower.includes("ravi") || nameLower.includes("george") || nameLower.includes("baskara") || nameLower.includes("wira")) {
                  gender = "Laki-laki";
                }
                return {
                  id: voiceName,
                  name: voiceName.replace(/Microsoft|Google|Apple/g, "").trim(),
                  lang: v.lang || "id-ID",
                  gender,
                  engine: "system",
                  isLocal: v.localService,
                  nativeVoice: v
                };
              });
            setSystemVoices(mapped);
          }
        } catch (err) {
          console.error("Gagal memuat suara browser lokal:", err);
        }
      }
    };

    loadSystemVoices();
    const synth = getSpeechSynthesis();
    if (synth) {
      try {
        synth.onvoiceschanged = loadSystemVoices;
      } catch (e) {
        console.warn("Gagal meregistrasi handler onvoiceschanged:", e);
      }
    }

    return () => {
      // Cleanup audio
      if (audioRef.current) {
        audioRef.current.pause();
      }
      const synthCleanup = getSpeechSynthesis();
      if (synthCleanup) {
        try {
          synthCleanup.cancel();
        } catch (e) {
          console.warn("Gagal cancel speech synthesis:", e);
        }
      }
    };
  }, []);

  // Separate effect to safely clean up any remaining object URL on unmount
  useEffect(() => {
    return () => {
      setActiveAudioUrl(prevUrl => {
        if (prevUrl) {
          try {
            URL.revokeObjectURL(prevUrl);
          } catch (e) {
            console.warn(e);
          }
        }
        return null;
      });
    };
  }, []);

  // Save history to storage when updated
  const saveHistoryToStorage = (newHistory: HistoryItem[]) => {
    setHistory(newHistory);
    safeLocalStorage.setItem("tts_history_logs", JSON.stringify(newHistory));
  };

  const showToast = (text: string, type: "success" | "error" | "info" = "success") => {
    setToastMessage({ text, type });
    setTimeout(() => setToastMessage(null), 4000);
  };

  // Switch engines & update selected voice automatically
  const handleEngineChange = (engine: "ai" | "system") => {
    setSelectedEngine(engine);
    if (engine === "ai") {
      setSelectedVoiceId("Kore");
    } else {
      if (systemVoices.length > 0) {
        // Try to pre-select Indonesian voice if present, else first voice
        const idVoice = systemVoices.find(v => v.lang.includes("id"));
        setSelectedVoiceId(idVoice ? idVoice.id : systemVoices[0].id);
      } else {
        setSelectedVoiceId("");
      }
    }
    // Stop playing when changing engine
    handleStop();
  };

  // Convert Text to Speech Action
  const handleGenerateAndPlay = async () => {
    if (!text.trim()) {
      showToast("Harap masukkan naskah teks terlebih dahulu.", "error");
      return;
    }

    // Stop existing playbacks
    handleStop();

    if (selectedEngine === "ai") {
      setIsGenerating(true);
      try {
        const matchedVoice = GEMINI_VOICES.find(v => v.id === selectedVoiceId);
        const voiceToSend = matchedVoice && matchedVoice.baseVoice ? matchedVoice.baseVoice : selectedVoiceId;

        const response = await fetch("/api/tts", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            text: text,
            voice: voiceToSend,
            emotion: aiEmotion,
            customApiKey: geminiApiKey
          })
        });

        if (!response.ok) {
          const errData = await response.json();
          throw new Error(errData.error || "Gagal menghubungi API.");
        }

        const data = await response.json();
        if (data.success && data.audio) {
          const audioMimeType = data.mimeType || "audio/wav";
          const binaryStr = atob(data.audio);
          const len = binaryStr.length;
          const bytes = new Uint8Array(len);
          for (let i = 0; i < len; i++) {
            bytes[i] = binaryStr.charCodeAt(i);
          }
          const blob = new Blob([bytes], { type: audioMimeType });
          const url = URL.createObjectURL(blob);
          
          setActiveAudioBlob(blob);
          setActiveAudioUrl(prevUrl => {
            if (prevUrl) {
              try {
                URL.revokeObjectURL(prevUrl);
              } catch (e) {
                console.warn(e);
              }
            }
            return url;
          });

          // Build audio player
          const audio = new Audio(url);
          audioRef.current = audio;
          
          audio.onplay = () => setIsPlaying(true);
          audio.onended = () => setIsPlaying(false);
          audio.onpause = () => setIsPlaying(false);
          audio.onerror = () => {
            showToast("Gagal memutar audio.", "error");
            setIsPlaying(false);
          };

          // Play audio
          audio.play().catch(err => {
            console.warn("audio.play() was prevented by browser/iframe restrictions:", err);
          });

          // Add to history
          const matchedVoice = GEMINI_VOICES.find(v => v.id === selectedVoiceId);
          const newHistoryItem: HistoryItem = {
            id: Date.now().toString(),
            text: text.substring(0, 160) + (text.length > 160 ? "..." : ""),
            timestamp: new Date().toLocaleTimeString("id-ID", { hour: "2-digit", minute: "2-digit" }),
            engine: "ai",
            voiceId: selectedVoiceId,
            voiceName: matchedVoice ? `${matchedVoice.name} (AI)` : selectedVoiceId,
            emotion: aiEmotion,
            audioBase64: data.audio,
            audioMimeType: audioMimeType
          };
          saveHistoryToStorage([newHistoryItem, ...history]);
          showToast("Berhasil menghasilkan suara neural AI!", "success");
        } else {
          throw new Error("Format audio tidak sesuai dari server.");
        }
      } catch (err: any) {
        console.error(err);
        showToast(err.message || "Gagal memproses suara neural AI.", "error");
      } finally {
        setIsGenerating(false);
      }
    } else {
      // Browser SpeechSynthesis Engine
      const synth = getSpeechSynthesis();
      if (!synth) {
        showToast("Speech synthesis tidak didukung oleh browser Anda atau dibatasi dalam frame ini.", "error");
        return;
      }

      setIsGenerating(true);
      setTimeout(() => {
        try {
          const utterance = new SpeechSynthesisUtterance(text);
          utteranceRef.current = utterance;

          const matchedSystemVoice = systemVoices.find(v => v.id === selectedVoiceId);
          if (matchedSystemVoice && matchedSystemVoice.nativeVoice) {
            utterance.voice = matchedSystemVoice.nativeVoice;
          }
          
          // Configure parameters
          utterance.rate = speed;
          utterance.pitch = pitch;

          utterance.onstart = () => {
            setIsGenerating(false);
            setIsPlaying(true);
          };

          utterance.onend = () => {
            setIsPlaying(false);
          };

          utterance.onerror = (e) => {
            console.error(e);
            setIsGenerating(false);
            setIsPlaying(false);
            showToast("Gagal memproses speech synthesis.", "error");
          };

          synth.speak(utterance);

          const newHistoryItem: HistoryItem = {
            id: Date.now().toString(),
            text: text.substring(0, 160) + (text.length > 160 ? "..." : ""),
            timestamp: new Date().toLocaleTimeString("id-ID", { hour: "2-digit", minute: "2-digit" }),
            engine: "system",
            voiceId: selectedVoiceId,
            voiceName: matchedSystemVoice ? `${matchedSystemVoice.name} (Sistem)` : "Suara Sistem",
            speed,
            pitch
          };
          saveHistoryToStorage([newHistoryItem, ...history]);
        } catch (e) {
          console.error(e);
          setIsGenerating(false);
          setIsPlaying(false);
          showToast("Proses speech synthesis diblokir atau gagal.", "error");
        }
      }, 300);
    }
  };

  // Play and Pause Toggle
  const handleTogglePlay = () => {
    if (selectedEngine === "ai") {
      if (audioRef.current) {
        if (isPlaying) {
          audioRef.current.pause();
        } else {
          audioRef.current.play().catch(err => {
            console.warn("audioRef.current.play() was prevented by browser/iframe restrictions:", err);
          });
        }
      } else {
        handleGenerateAndPlay();
      }
    } else {
      // System engine has native pause and resume methods
      const synth = getSpeechSynthesis();
      if (synth) {
        if (isPlaying) {
          try {
            synth.pause();
          } catch (e) {
            console.error(e);
          }
          setIsPlaying(false);
        } else {
          if (synth.paused) {
            try {
              synth.resume();
            } catch (e) {
              console.error(e);
            }
            setIsPlaying(true);
          } else {
            handleGenerateAndPlay();
          }
        }
      } else {
        showToast("Suara sistem tidak didukung di lingkungan ini.", "info");
      }
    }
  };

  // Stop completely
  const handleStop = () => {
    if (audioRef.current) {
      audioRef.current.pause();
      audioRef.current.currentTime = 0;
    }
    const synth = getSpeechSynthesis();
    if (synth) {
      try {
        synth.cancel();
      } catch (e) {
        console.error(e);
      }
    }
    setIsPlaying(false);
    setActiveHistoryPlayingId(null);
  };

  // Play older clips directly from history instantly without querying API again!
  const handlePlayHistory = (item: HistoryItem) => {
    handleStop();
    
    if (item.engine === "ai" && item.audioBase64) {
      setActiveHistoryPlayingId(item.id);
      setIsPlaying(true);
      
      const audioMimeType = item.audioMimeType || "audio/wav";
      const binaryStr = atob(item.audioBase64);
      const len = binaryStr.length;
      const bytes = new Uint8Array(len);
      for (let i = 0; i < len; i++) {
        bytes[i] = binaryStr.charCodeAt(i);
      }
      const blob = new Blob([bytes], { type: audioMimeType });
      const url = URL.createObjectURL(blob);
      
      setActiveAudioBlob(blob);
      setActiveAudioUrl(prevUrl => {
        if (prevUrl) {
          try {
            URL.revokeObjectURL(prevUrl);
          } catch (e) {
            console.warn(e);
          }
        }
        return url;
      });

      const audio = new Audio(url);
      audioRef.current = audio;
      
      audio.onended = () => {
        setIsPlaying(false);
        setActiveHistoryPlayingId(null);
      };
      audio.onerror = () => {
        setIsPlaying(false);
        setActiveHistoryPlayingId(null);
        showToast("Audio kedaluwarsa atau corrupt.", "error");
      };
      audio.play().catch(err => {
        console.warn("audio.play() in handlePlayHistory was prevented by browser/iframe restrictions:", err);
      });
    } else {
      // Re-read history item using Browser synthesis
      setSelectedEngine("system");
      setSelectedVoiceId(item.voiceId);
      if (item.speed) setSpeed(item.speed);
      if (item.pitch) setPitch(item.pitch);
      
      // Load current text block as active text
      // We will perform read
      showToast("Memuat ulang teks dan suara dari riwayat...", "info");
    }
  };

  // Clear history logs
  const handleClearHistory = () => {
    saveHistoryToStorage([]);
    showToast("Semua riwayat berhasil dihapus.", "success");
  };

  // Delete single history log
  const handleDeleteHistoryItem = (id: string, e: React.MouseEvent) => {
    e.stopPropagation(); // Avoid triggering replay activity
    const filtered = history.filter(item => item.id !== id);
    saveHistoryToStorage(filtered);
    showToast("Item riwayat dihapus.", "success");
  };

  // Helper to trigger direct file download
  const downloadBlob = (blob: Blob, fileName: string) => {
    const link = document.createElement("a");
    const url = URL.createObjectURL(blob);
    link.href = url;
    link.download = fileName;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    setTimeout(() => {
      URL.revokeObjectURL(url);
    }, 100);
  };

  // Download active synthesized audio
  const handleDownloadAudio = (format: "wav" | "mp3") => {
    if (!activeAudioBlob) {
      showToast("Tidak ada audio hasil sintesis yang siap diunduh.", "error");
      return;
    }

    const textSnippet = text.trim()
      ? text.trim().substring(0, 20).replace(/[^a-zA-Z0-9]/g, "_")
      : "audio";
    const voiceName = selectedVoiceId || "suara";
    const fileName = `tts_${voiceName}_${textSnippet}.${format}`;

    const mimeType = format === "mp3" ? "audio/mp3" : (activeAudioBlob.type || "audio/wav");
    const typedBlob = new Blob([activeAudioBlob], { type: mimeType });

    downloadBlob(typedBlob, fileName);
    showToast(`Berhasil mengunduh audio sebagai ${format.toUpperCase()}!`, "success");
  };

  // Download a historical audio directly
  const handleDownloadHistoryItem = (item: HistoryItem, format: "wav" | "mp3", e: React.MouseEvent) => {
    e.stopPropagation(); // Avoid triggering play history item
    if (!item.audioBase64) return;

    try {
      const binaryStr = atob(item.audioBase64);
      const len = binaryStr.length;
      const bytes = new Uint8Array(len);
      for (let i = 0; i < len; i++) {
        bytes[i] = binaryStr.charCodeAt(i);
      }
      
      const mimeType = format === "mp3" ? "audio/mp3" : (item.audioMimeType || "audio/wav");
      const blob = new Blob([bytes], { type: mimeType });

      const textSnippet = item.text
        ? item.text.substring(0, 20).replace(/[^a-zA-Z0-9]/g, "_")
        : "audio_history";
      const fileName = `tts_history_${item.voiceId}_${textSnippet}.${format}`;

      downloadBlob(blob, fileName);
      showToast(`Berhasil mengunduh riwayat audio sebagai ${format.toUpperCase()}!`, "success");
    } catch (err) {
      console.error(err);
      showToast("Gagal memproses pengunduhan riwayat audio.", "error");
    }
  };

  // Validate and save custom Gemini API key
  const handleSaveApiKey = async () => {
    const trimmed = inputApiKey.trim();
    if (!trimmed) {
      setGeminiApiKey("");
      safeLocalStorage.setItem("gemini_api_key", "");
      showToast("Kunci API kustom dikosongkan. Sistem akan menggunakan kunci server bawaan jika tersedia.", "info");
      return;
    }

    setIsValidatingKey(true);
    try {
      const response = await fetch("/api/validate-key", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ customApiKey: trimmed })
      });

      const data = await response.json();
      if (response.ok && data.success) {
        setGeminiApiKey(trimmed);
        safeLocalStorage.setItem("gemini_api_key", trimmed);
        showToast("Kunci API berhasil diverifikasi dan disimpan secara lokal!", "success");
      } else {
        showToast(data.error || "Kunci API tidak valid. Pastikan Anda menyalinnya dengan benar.", "error");
      }
    } catch (err: any) {
      console.error(err);
      showToast("Gagal memverifikasi Kunci API karena kesalahan koneksi.", "error");
    } finally {
      setIsValidatingKey(false);
    }
  };

  // Clear / remove custom API key
  const handleClearApiKey = () => {
    setInputApiKey("");
    setGeminiApiKey("");
    safeLocalStorage.setItem("gemini_api_key", "");
    showToast("Kunci API kustom berhasil dihapus dari perangkat.", "success");
  };

  // Enhance Text using prompt AI
  const handleEnhanceTextWithAI = async (mode: string) => {
    if (!text.trim()) return;
    setIsGenerating(true);
    try {
      const response = await fetch("/api/enhance", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ 
          text, 
          mode,
          customApiKey: geminiApiKey 
        })
      });

      if (!response.ok) {
        throw new Error("Gagal menyempurnakan naskah.");
      }

      const data = await response.json();
      if (data.success && data.enhancedText) {
        setText(data.enhancedText);
        showToast(`Teks berhasil diperbaiki dengan gaya ${mode === 'formal' ? 'Formal' : mode === 'casual' ? 'Santai' : mode === 'storytelling' ? 'Dongeng' : 'Puitis'}!`, "success");
      }
    } catch (e: any) {
      showToast(e.message || "Gagal menyempurnakan teks.", "error");
    } finally {
      setIsGenerating(false);
    }
  };

  // Apply Preset template naskah
  const handleSelectPreset = (presetText: string) => {
    setText(presetText);
    showToast("Naskah dimasukkan ke editor.", "info");
  };

  // Copy text to clipboard
  const handleCopyText = (content: string, id: string) => {
    navigator.clipboard.writeText(content);
    setCopiedId(id);
    setTimeout(() => setCopiedId(null), 2000);
    showToast("Teks disalin ke clipboard!", "success");
  };

  // Active voice configuration object
  const activeVoiceName = selectedEngine === "ai" 
    ? (GEMINI_VOICES.find(v => v.id === selectedVoiceId)?.name || "Kore")
    : (systemVoices.find(v => v.id === selectedVoiceId)?.name || "Local Voice");

  return (
    <div className="min-h-screen bg-[#09090b] text-[#fafafa] flex flex-col font-sans selection:bg-indigo-600/30">
      
      {/* Toast Notification HUD */}
      {toastMessage && (
